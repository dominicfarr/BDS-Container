{
  "testEnvironment": "jsdom",
  "transform": {
    "^.+\\.(js|jsx)$": "babel-jest"
  },
  "moduleNameMapper": {
    "\\.(css|less|scss|sass)$": "<rootDir>/src/__mocks__/styleMock.js"
  },
  "setupFilesAfterEnv": ["<rootDir>/src/setupTests.js"],
  "testPathIgnorePatterns": ["/node_modules/", "/e2e/"]
}
